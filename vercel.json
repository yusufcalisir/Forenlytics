{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/main.py"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ],
  "functions": {
    "backend/main.py": {
      "runtime": "vercel-python@0.1.0",
      "memory": 3008,
      "maxDuration": 30
    }
  }
}
